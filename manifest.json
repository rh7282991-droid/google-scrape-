{
  "manifest_version": 3,
  "name": "Google Lead Scraper Pro",
  "version": "3.4.1",
  "description": "Advanced lead scraper for Google Search. CAPTCHA detection, multi-account rotation, smart suggestions, location auto-expand, deep enrichment, resume on failure.",
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "notifications",
    "alarms",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://google.com/*",
    "https://suggestqueries.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Google Lead Scraper Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://google.com/search*",
        "https://www.google.com/sorry/*",
        "https://sorry.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
