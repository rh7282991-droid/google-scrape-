{
  "manifest_version": 3,
  "name": "Google Lead Scraper",
  "version": "1.0.0",
  "description": "Collect business leads from Google Maps - phones, emails, websites, addresses. Free, no API needed.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/logo.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.google.com.bd/*",
    "https://www.google.co.in/*",
    "https://www.google.co.uk/*",
    "*://www.google.*/*"
  ]
}
