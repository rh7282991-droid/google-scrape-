{
  "manifest_version": 3,
  "name": "Maps Lead Scraper Pro",
  "version": "6.0.0",
  "description": "Advanced Google Maps lead scraper. Extract business name, phone, address, website, email, social links from Google Maps profiles. CAPTCHA-safe with multi-account rotation.",
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "notifications",
    "alarms",
    "clipboardRead"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.google.co.bd/*",
    "*://*.google.co.in/*",
    "*://*.google.co.uk/*",
    "*://*.google.com.bd/*",
    "*://*.google.com.au/*",
    "*://*.google.com.sg/*",
    "*://*.google.com.pk/*",
    "*://maps.google.com/*",
    "https://suggestqueries.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maps Lead Scraper Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/maps/*",
        "*://*.google.co.bd/maps/*",
        "*://*.google.co.in/maps/*",
        "*://*.google.co.uk/maps/*",
        "*://*.google.co.jp/maps/*",
        "*://*.google.co.th/maps/*",
        "*://*.google.co.kr/maps/*",
        "*://*.google.co.id/maps/*",
        "*://*.google.co.za/maps/*",
        "*://*.google.com.bd/maps/*",
        "*://*.google.com.au/maps/*",
        "*://*.google.com.sg/maps/*",
        "*://*.google.com.pk/maps/*",
        "*://*.google.com.br/maps/*",
        "*://*.google.com.sa/maps/*",
        "*://*.google.com.eg/maps/*",
        "*://*.google.com.tr/maps/*",
        "*://*.google.com.ng/maps/*",
        "*://*.google.com.my/maps/*",
        "*://*.google.com.ph/maps/*",
        "*://*.google.com.mx/maps/*",
        "*://*.google.ae/maps/*",
        "*://*.google.de/maps/*",
        "*://*.google.fr/maps/*",
        "*://*.google.es/maps/*",
        "*://*.google.it/maps/*",
        "*://*.google.ca/maps/*",
        "*://*.google.nl/maps/*",
        "*://*.google.se/maps/*",
        "*://*.google.ru/maps/*",
        "*://maps.google.com/*",
        "*://maps.google.co.bd/*",
        "*://maps.google.co.in/*",
        "*://maps.google.co.uk/*",
        "*://*.google.com/search*",
        "*://*.google.co.bd/search*",
        "*://*.google.co.in/search*",
        "*://*.google.com/sorry/*",
        "*://*.google.co.bd/sorry/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
